{
    "version": 2,
    "buildCommand": "chmod +x build_files.sh && ./build_files.sh",
    "builds": [
        {
            "src": "tweet_project/wsgi.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "tweet_project/wsgi.py"
        }
    ]
}
