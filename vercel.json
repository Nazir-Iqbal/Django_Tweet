{
    "version": 2,
    "buildCommand": "chmod +x build_files.sh && ./build_files.sh",
    "outputDirectory": "staticfiles",
    "functions": {
        "tweet_project/wsgi.py": {
            "runtime": "vercel-python@3"
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "tweet_project/wsgi.py"
        }
    ]
}
